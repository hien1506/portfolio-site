---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import SketchpadHero from "../components/SketchpadHero.astro";
import ProjectFilter from "../components/ProjectFilter.astro";
import ProjectGrid from "../components/ProjectGrid.astro";

const allProjects = await getCollection("projects", ({ data }) => !data.draft);

const projects = allProjects
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime())
  .map((entry) => ({
    title: entry.data.title,
    description: entry.data.description,
    image: entry.data.image ?? "",
    link: entry.data.externalUrl ?? `/projects/${entry.id}`,
    category: entry.data.category,
  }));

const counts = {
  all: projects.length,
  project: projects.filter((p) => p.category === "project").length,
  writing: projects.filter((p) => p.category === "writing").length,
  experiment: projects.filter((p) => p.category === "experiment").length,
};
---

<Layout>
  <SketchpadHero />

  <div class="px-4 pb-16">
    <ProjectFilter counts={counts} />
    <ProjectGrid projects={projects} />
  </div>
</Layout>
