---
import Layout from "../layouts/Layout.astro";
import { recommendations } from "../data/recommendations";
---

<Layout title="About">
  <article class="px-4 pt-0 pb-16">
    <div
      class="grid grid-cols-1 gap-12 md:gap-16 border-t border-dotted border-primary/25 pt-8 md:pt-12 md:grid-cols-2"
    >
      <div>
        <h2
          class="mb-4 text-xs font-medium uppercase tracking-widest text-text text-pretty"
        >
          ABOUT
        </h2>
        <div class="flex max-w-prose flex-col gap-6">
          <p class="text-sm leading-relaxed text-text">
            I'm a frontend developer from Melbourne, Australia. I am curious
            person who loves trying new things and am currently learning
            creative web technologies like p5.js and three.js.
          </p>
          <p class="text-sm leading-relaxed text-text">
            Most of the work here is an attempt to make digital spaces that are
            a little more playful.
          </p>
          <figure class="profile-wrap mt-2 w-full overflow-hidden">
            <img
              src="/images/profile-picture.webp"
              alt="A photo of Hien Nguyen taken in a cafe in Tokyo, Japan"
              width="600"
              height="600"
              loading="lazy"
              class="profile-img aspect-square w-full object-cover border-primary border-3"
            />
            <figcaption class="py-2 text-xs text-faint">
              Taken in Tokyo, Japan
            </figcaption>
          </figure>
          <p class="text-sm leading-relaxed text-text">
            I enjoy photography, spending time in movie theaters and am a
            volunteer at the <a
              class="underline decoration-text/20 underline-offset-[3px] transition-[text-decoration-color] duration-150 ease hover:decoration-text active:opacity-70 motion-reduce:transition-none"
              href="https://altonanorthdojo.com/"
              rel="noopener">Altona North Coder Dojo</a
            >. If my work resonates with you, please reach out.
          </p>
          <div class="flex flex-col gap-1 pt-1">
            <div class="text-sm leading-relaxed">
              <span class="font-medium">Email:</span>
              <a
                href="mailto:hiennguyen1529@gmail.com"
                class="text-text underline decoration-text/20 underline-offset-[3px] transition-[text-decoration-color] duration-150 ease hover:decoration-text active:opacity-70 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary motion-reduce:transition-none"
                >hiennguyen1529@gmail.com</a
              >
            </div>
            <div class="text-sm leading-relaxed">
              <span class="font-medium">Arena:</span>
              <a
                href="https://www.are.na/hien-nguyen"
                target="_blank"
                rel="noopener noreferrer"
                class="text-text underline decoration-text/20 underline-offset-[3px] transition-[text-decoration-color] duration-150 ease hover:decoration-text active:opacity-70 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary motion-reduce:transition-none"
                >are.na/hien<span class="sr-only"> (opens in new tab)</span></a
              >
            </div>
            <div class="text-sm leading-relaxed">
              <span class="font-medium">Instagram:</span>
              <a
                href="https://www.instagram.com/hiennguyen1529"
                target="_blank"
                rel="noopener noreferrer"
                class="text-text underline decoration-text/20 underline-offset-[3px] transition-[text-decoration-color] duration-150 ease hover:decoration-text active:opacity-70 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary motion-reduce:transition-none"
                >@hiennguyen1529<span class="sr-only">
                  (opens in new tab)</span
                ></a
              >
            </div>
          </div>
        </div>
      </div>
      <div>
        <h2
          class="mb-4 text-xs font-medium uppercase tracking-widest text-text text-pretty"
        >
          Recommending
        </h2>
        {
          recommendations.length === 0 ? (
            <p class="text-sm">Nothing here yet.</p>
          ) : (
            <ul role="list" class="flex list-none flex-col p-0">
              {recommendations.map((rec, i) => (
                <li
                  class:list={[
                    i !== recommendations.length - 1 &&
                      "border-b border-primary/8",
                  ]}
                >
                  <a
                    href={rec.link}
                    target="_blank"
                    rel="noopener noreferrer"
                    class:list={[
                      "grid grid-cols-[8rem_1fr] items-stretch gap-4 no-underline text-inherit transition-[background-color] duration-150 ease hover:bg-black/3 active:opacity-60 focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-primary rounded-sm motion-reduce:transition-none",
                      i === 0 && "pt-0",
                    ]}
                  >
                    {rec.image ? (
                      <img
                        src={rec.image}
                        alt=""
                        class="w-full aspect-square object-cover"
                        loading="lazy"
                      />
                    ) : (
                      <div
                        class="w-full aspect-square"
                        style={`background-color: ${rec.color}`}
                        aria-hidden="true"
                      />
                    )}
                    <div class="flex min-w-0 flex-col gap-2 py-4">
                      <h3 class="text-base font-medium leading-tight text-pretty">
                        {rec.title}
                      </h3>
                      <p class="line-clamp-2 text-sm leading-relaxed">
                        {rec.description}
                      </p>
                      <span class="mt-1 text-xs text-faint">
                        [{rec.category}]
                      </span>
                    </div>
                  </a>
                </li>
              ))}
            </ul>
          )
        }
      </div>
    </div>
  </article>
</Layout>
