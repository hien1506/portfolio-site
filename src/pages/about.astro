---
import Layout from "../layouts/Layout.astro";

const recommendations = [
  {
    title: "Designing Programs",
    description:
      "Karl Gerstner's systematic approach to design. A framework for thinking about visual rules as generative systems.",
    category: "Book",
    color: "#202d85",
  },
  {
    title: "Uxn / Varvara",
    description:
      "A personal computing stack built for longevity. Small tools, made to last, running on a tiny virtual machine.",
    category: "Tool",
    color: "#5a7a5a",
  },
  {
    title: "The Web's Grain",
    description:
      "Frank Chimero on designing for the web's natural material properties rather than fighting against them.",
    category: "Essay",
    color: "#d4a033",
  },
  {
    title: "Figma",
    description:
      "Still the best multiplayer design tool. The plugin ecosystem and community resources are unmatched.",
    category: "Tool",
    color: "#c4523a",
  },
  {
    title: "Learning Synths",
    description:
      "Ableton's interactive guide to synthesis. Beautiful example of teaching through direct manipulation.",
    category: "Interactive",
    color: "#c97b8b",
  },
];
---

<Layout>
  <article class="px-4 pt-4 pb-16">
    <div class="grid grid-cols-1 gap-12 md:grid-cols-2 md:gap-8">
      <!-- Left column: Bio -->
      <div>
        <div class="mb-6 border-t border-dotted border-primary/25"></div>
        <div class="flex flex-col gap-6">
          <p class="text-[0.9375rem] leading-relaxed text-text">
            Designer and developer interested in building tools that feel
            intuitive and humane. Currently exploring the intersection of
            interaction design and creative coding.
          </p>
          <p class="text-[0.9375rem] leading-relaxed text-text">
            Most of the work here is an attempt to make digital spaces that are
            a little more playful, a little more considered.
          </p>
          <div class="mt-2 w-full overflow-hidden rounded-md">
            <img
              src="/profile.jpg"
              alt="Hien Nguyen"
              width="600"
              height="600"
              loading="lazy"
              class="aspect-square w-full object-cover"
            />
          </div>
          <div class="flex flex-col gap-1 pt-1">
            <div class="text-sm leading-relaxed">
              <span class="font-semibold">Email:</span>
              <a
                href="mailto:hiennguyen1529@gmail.com"
                class="text-text underline decoration-primary/30 underline-offset-[3px] transition-colors duration-150 ease-out hover:decoration-primary focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary motion-reduce:transition-none"
                >hiennguyen1529@gmail.com</a
              >
            </div>
            <div class="text-sm leading-relaxed">
              <span class="font-semibold">Arena:</span>
              <a
                href="https://www.are.na/hien-nguyen"
                target="_blank"
                rel="noopener noreferrer"
                class="text-text underline decoration-primary/30 underline-offset-[3px] transition-colors duration-150 ease-out hover:decoration-primary focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary motion-reduce:transition-none"
                >are.na/hien</a
              >
            </div>
          </div>
        </div>
      </div>

      <!-- Right column: Recommendations -->
      <div>
        <div class="mb-6 border-t border-dotted border-primary/25"></div>
        <h2
          class="mb-5 text-xs font-semibold uppercase tracking-widest text-text"
        >
          Recommending
        </h2>
        <ul class="flex list-none flex-col p-0">
          {
            recommendations.map((rec, i) => (
              <li
                class:list={[
                  "grid grid-cols-[5.5rem_1fr] items-start gap-4 py-5",
                  i === 0 && "pt-0",
                  i !== recommendations.length - 1 &&
                    "border-b border-primary/8",
                ]}
              >
                <div
                  class="aspect-square w-full rounded"
                  style={`background-color: ${rec.color}`}
                />
                <div class="flex flex-col gap-1.5">
                  <h3 class="text-[0.9375rem] font-semibold leading-tight">
                    {rec.title}
                  </h3>
                  <p class="text-[0.8125rem] leading-relaxed text-neutral-500">
                    {rec.description}
                  </p>
                  <span class="mt-1 text-xs text-neutral-500">
                    [{rec.category}]
                  </span>
                </div>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </article>
</Layout>
