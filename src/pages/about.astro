---
import Layout from "../layouts/Layout.astro";

const recommendations = [
  {
    title: "Designing Programs",
    description:
      "Karl Gerstner's systematic approach to design. A framework for thinking about visual rules as generative systems.",
    category: "Book",
    color: "#202d85",
  },
  {
    title: "Uxn / Varvara",
    description:
      "A personal computing stack built for longevity. Small tools, made to last, running on a tiny virtual machine.",
    category: "Tool",
    color: "#5a7a5a",
  },
  {
    title: "The Web's Grain",
    description:
      "Frank Chimero on designing for the web's natural material properties rather than fighting against them.",
    category: "Essay",
    color: "#d4a033",
  },
  {
    title: "Figma",
    description:
      "Still the best multiplayer design tool. The plugin ecosystem and community resources are unmatched.",
    category: "Tool",
    color: "#c4523a",
  },
  {
    title: "Learning Synths",
    description:
      "Ableton's interactive guide to synthesis. Beautiful example of teaching through direct manipulation.",
    category: "Interactive",
    color: "#c97b8b",
  },
];
---

<Layout>
  <article class="about-page px-4 pt-4 pb-16">
    <div class="about-grid">
      <!-- Left column: Bio -->
      <div class="about-bio">
        <div class="border-rule"></div>
        <div class="bio-content">
          <p class="bio-text">
            Designer and developer interested in building tools that feel
            intuitive and humane. Currently exploring the intersection of
            interaction design and creative coding.
          </p>
          <p class="bio-text">
            Most of the work here is an attempt to make digital spaces that are
            a little more playful, a little more considered.
          </p>
          <div class="bio-image-wrap">
            <img src="/profile.jpg" alt="Hien Nguyen" class="bio-image" />
          </div>

          <div class="bio-links">
            <div class="bio-link-row">
              <span class="bio-link-label">Email:</span>
              <a href="mailto:hiennguyen1529@gmail.com"
                >hiennguyen1529@gmail.com</a
              >
            </div>
            <div class="bio-link-row">
              <span class="bio-link-label">Arena:</span>
              <a
                href="https://www.are.na/hien-nguyen"
                target="_blank"
                rel="noopener noreferrer">are.na/hien</a
              >
            </div>
          </div>
        </div>
      </div>

      <!-- Right column: Recommendations -->
      <div class="about-recs">
        <div class="border-rule"></div>
        <h2 class="recs-heading">Recommending</h2>
        <ul class="recs-list">
          {
            recommendations.map((rec) => (
              <li class="rec-item">
                <div
                  class="rec-swatch"
                  style={`background-color: ${rec.color}`}
                />
                <div class="rec-body">
                  <h3 class="rec-title">{rec.title}</h3>
                  <p class="rec-desc">{rec.description}</p>
                  <span class="rec-category">[{rec.category}]</span>
                </div>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </article>
</Layout>

<style>
  .about-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }

  @media (min-width: 768px) {
    .about-grid {
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
    }
  }

  /* Dotted rule at top of each column */
  .border-rule {
    border-top: 1.5px dotted rgba(32, 45, 133, 0.25);
    margin-bottom: 1.5rem;
  }

  /* Bio column */
  .bio-content {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .bio-text {
    font-size: 0.9375rem;
    line-height: 1.7;
    color: var(--color-text);
    margin: 0;
  }

  .bio-links {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding-top: 0.25rem;
  }

  .bio-link-row {
    font-size: 0.875rem;
    line-height: 1.6;
  }

  .bio-link-label {
    font-weight: 600;
  }

  .bio-link-row a {
    color: var(--color-text);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: rgba(32, 45, 133, 0.3);
    transition: text-decoration-color 0.15s ease;
  }

  .bio-link-row a:hover {
    text-decoration-color: var(--color-primary);
  }

  .bio-link-row a:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }

  .bio-image-wrap {
    width: 100%;
    aspect-ratio: 1;
    border-radius: 0.375rem;
    overflow: hidden;
    margin-top: 0.5rem;
  }

  .bio-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Recommendations column */
  .recs-heading {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text);
    margin: 0 0 1.25rem;
  }

  .recs-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
  }

  .rec-item {
    display: grid;
    grid-template-columns: 5.5rem 1fr;
    gap: 1rem;
    padding: 1.25rem 0;
    border-bottom: 1px solid rgba(32, 45, 133, 0.08);
    align-items: start;
  }

  .rec-item:first-child {
    padding-top: 0;
  }

  .rec-item:last-child {
    border-bottom: none;
  }

  .rec-swatch {
    width: 100%;
    aspect-ratio: 1;
    border-radius: 0.25rem;
  }

  .rec-body {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .rec-title {
    font-size: 0.9375rem;
    font-weight: 600;
    line-height: 1.3;
    margin: 0;
  }

  .rec-desc {
    font-size: 0.8125rem;
    line-height: 1.6;
    color: #6b6b6b;
    margin: 0;
  }

  .rec-category {
    font-size: 0.75rem;
    color: #6b6b6b;
    margin-top: 0.25rem;
  }

  @media (prefers-reduced-motion: reduce) {
    .bio-link-row a {
      transition: none;
    }
  }
</style>
