---
import "../styles/global.css";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";

import font300 from "@fontsource/ibm-plex-mono/files/ibm-plex-mono-latin-300-normal.woff2?url";
import font400 from "@fontsource/ibm-plex-mono/files/ibm-plex-mono-latin-400-normal.woff2?url";
import font500 from "@fontsource/ibm-plex-mono/files/ibm-plex-mono-latin-500-normal.woff2?url";

interface Props {
  title?: string;
  description?: string;
  hideNav?: boolean;
  hideFooter?: boolean;
}

const {
  title = "Hien Nguyen",
  description = "Frontend developer from Melbourne, Australia. Building friendly and safe web experiences.",
  hideNav = false,
  hideFooter = false,
} = Astro.props;

const pageTitle = title === "Hien Nguyen" ? title : `${title} — Hien Nguyen`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="preload" href={font300} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={font400} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={font500} as="font" type="font/woff2" crossorigin />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
  </head>
  <body>
    <div class="min-h-screen max-w-7xl mx-auto flex flex-col">
      {!hideNav && <Nav />}
      <main class="flex-1">
        <slot />
      </main>
      {!hideFooter && <Footer />}
    </div>
  </body>
</html>
