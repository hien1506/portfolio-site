---
type Category = "project" | "writing" | "experiment";

interface FilterOption {
  label: string;
  value: "all" | Category;
}

const filters: FilterOption[] = [
  { label: "All", value: "all" },
  { label: "Project", value: "project" },
  { label: "Writing", value: "writing" },
  { label: "Experiment", value: "experiment" },
];
---

<nav aria-label="Project filters" class="mb-8">
  <div class="flex flex-col gap-2">
    <h2 class="text-xs font-semibold uppercase tracking-widest text-pretty">Projects</h2>
    <div class="flex flex-wrap items-center gap-x-4 gap-y-2">
      {
        filters.map((filter) => (
          <button
            type="button"
            class="filter-btn text-sm uppercase tracking-widest transition-colors duration-150 ease-out focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
            data-filter={filter.value}
            aria-pressed={filter.value === "all" ? "true" : "false"}
          >
            <span class="filter-check" aria-hidden="true" />
            {filter.label}
          </button>
        ))
      }
    </div>
  </div>
</nav>

<style>
  .filter-btn {
    cursor: pointer;
    background: none;
    border: none;
    padding: 0;
    touch-action: manipulation;
  }

  .filter-btn:hover {
    color: var(--color-primary);
  }

  .filter-check {
    display: inline-block;
    width: 1.5em;
    text-align: left;
  }

  .filter-check::before {
    content: "[]";
  }

  .filter-btn[aria-pressed="true"] .filter-check::before {
    content: "[x]";
  }
</style>

<script>
  function initFilters() {
    const buttons = document.querySelectorAll<HTMLButtonElement>(".filter-btn");
    const cards = document.querySelectorAll<HTMLElement>("[data-category]");

    function getFilterFromURL(): string {
      const params = new URLSearchParams(window.location.search);
      return params.get("filter") || "all";
    }

    function setFilterInURL(filter: string) {
      const url = new URL(window.location.href);
      if (filter === "all") {
        url.searchParams.delete("filter");
      } else {
        url.searchParams.set("filter", filter);
      }
      window.history.replaceState({}, "", url.toString());
    }

    function applyFilter(activeFilter: string) {
      buttons.forEach((btn) => {
        btn.setAttribute(
          "aria-pressed",
          btn.dataset.filter === activeFilter ? "true" : "false",
        );
      });

      cards.forEach((card) => {
        const category = card.dataset.category;
        const visible = activeFilter === "all" || category === activeFilter;
        card.style.display = visible ? "" : "none";
      });
    }

    buttons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const filter = btn.dataset.filter || "all";
        setFilterInURL(filter);
        applyFilter(filter);
      });
    });

    // Init from URL
    applyFilter(getFilterFromURL());
  }

  // Run on initial load and Astro view transitions
  initFilters();
  document.addEventListener("astro:after-swap", initFilters);
</script>
