---
import type { Category } from "../data/projects";

interface Props {
  title: string;
  description: string;
  image: string;
  link: string;
  category: Category;
}

const { title, description, image, link, category } = Astro.props;
---

<article data-category={category}>
  <a href={link} class="group block no-underline rounded-sm focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-primary">
    <div class="overflow-hidden rounded-sm bg-neutral-200">
      {
        image ? (
          <img
            src={image}
            alt={title}
            class="w-full h-auto block transition-transform duration-300 ease-out group-hover:scale-[1.02]"
            loading="lazy"
          />
        ) : (
          <div class="aspect-[4/3]" />
        )
      }
    </div>
    <div class="mt-3">
      <h3 class="text-sm font-semibold leading-tight">{title}</h3>
      <p class="mt-1 text-sm leading-snug text-neutral-600">
        {description}
      </p>
      <span
        class="mt-2 inline-block text-sm underline underline-offset-3 transition-colors duration-150 ease-out group-hover:text-primary"
      >
        View project
      </span>
    </div>
  </a>
</article>
