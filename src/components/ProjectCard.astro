---
interface Props {
  title: string;
  description: string;
  image: string;
  link: string;
  category: string;
}

const { title, description, image, link, category } = Astro.props;
---

<article data-category={category}>
  <a
    href={link}
    class="group flex flex-col gap-4 no-underline rounded-sm focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-primary"
  >
    <div class="overflow-hidden rounded-sm bg-neutral-200">
      {
        image ? (
          <img
            src={image}
            alt={title}
            class="w-full h-auto block"
            loading="lazy"
          />
        ) : (
          <div class="aspect-4/3" />
        )
      }
    </div>
    <div class="flex flex-col gap-2">
      <span class="text-xs uppercase tracking-widest text-faint">
        {category}
      </span>
      <h3 class="text-base font-semibold leading-tight text-pretty">{title}</h3>
      <p class="text-sm leading-relaxed text-muted">
        {description}
      </p>
    </div>
  </a>
</article>
