---
interface Props {
  title: string;
  description: string;
  image: string;
  link: string;
  category: string;
}

const { title, description, image, link, category } = Astro.props;
---

<article data-category={category}>
  <a
    href={link}
    class="group flex flex-col gap-4 no-underline rounded-sm focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-primary"
  >
    <div class="overflow-hidden rounded-sm bg-neutral-200">
      {
        image ? (
          <img
            src={image}
            alt={title}
            class="w-full h-auto block transition-transform duration-300 ease-out group-hover:scale-[1.02]"
            loading="lazy"
          />
        ) : (
          <div class="aspect-4/3" />
        )
      }
    </div>
    <div class="flex flex-col justify-between gap-4">
      <div class="flex flex-col gap-4">
        <h3 class="text-base font-semibold leading-tight">{title}</h3>
        <p class="text-base leading-snug text-neutral-600">
          {description}
        </p>
      </div>

      <span
        class="mt-2 inline-block text-base underline underline-offset-3 transition-colors duration-150 ease-out group-hover:text-primary"
      >
        View project
      </span>
    </div>
  </a>
</article>
