---
import ProjectCard from "./ProjectCard.astro";
import type { Project } from "../data/projects";

interface Props {
  projects: Project[];
}

const { projects } = Astro.props;
---

<section
  class="grid grid-cols-1 items-start gap-x-8 gap-y-16 sm:grid-cols-2 lg:grid-cols-4"
>
  {
    projects.map((project) => (
      <ProjectCard
        title={project.title}
        description={project.description}
        image={project.image}
        link={project.link}
      />
    ))
  }
</section>
