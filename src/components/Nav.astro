---
const currentPath = Astro.url.pathname.replace(/\/$/, "");
---

<nav class="flex justify-between items-center p-4">
  <a
    href="/"
    class="flex items-center gap-2 rounded text-ink no-underline transition-colors duration-150 ease hover:text-ink-muted motion-reduce:transition-none"
  >
    <span
      class="inline-block h-4 w-4 shrink-0 rounded-full bg-primary"
      aria-hidden="true"></span>
    <span class={currentPath === "" ? "font-bold" : ""}>Hien Nguyen</span>
  </a>
</nav>
