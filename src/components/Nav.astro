---
const currentPath = Astro.url.pathname.replace(/\/$/, "");
---

<nav class="flex justify-between items-center p-4 text-sm">
  <a
    href="/"
    class="flex items-center gap-2 rounded text-text no-underline hover:font-medium active:font-medium"
  >
    <span
      class="inline-block h-4 w-4 shrink-0 rounded-full bg-primary"
      aria-hidden="true"></span>
    <span>Hien Nguyen</span>
  </a>
  <ul class="flex items-center gap-4">
    <li>
      <a
        href="/#projects"
        class:list={[
          "text-text no-underline hover:font-medium active:font-medium",
          currentPath === "" ? "font-medium" : "",
        ]}
        >Projects</a
      >
    </li>
    <li>
      <a
        href="/about"
        class:list={[
          "text-text no-underline hover:font-medium active:font-medium",
          currentPath === "/about" ? "font-medium" : "",
        ]}
        >About</a
      >
    </li>
  </ul>
</nav>
